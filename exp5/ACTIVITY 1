class Library:

    def __init__(self):
        # Dictionary to store book name and price
        self.books = {
            "Python Basics": 500,
            "Data Structures": 700,
            "Machine Learning": 900
        }

    # Display all books
    def display_books(self):
        print("\nAvailable Books:")
        for book, price in self.books.items():
            print(f"{book} : ₹{price}")

    # Update book price
    def update_price(self, book_name, new_price):
        if book_name in self.books:
            old_price = self.books[book_name]
            self.books[book_name] = new_price
            print(f"\nPrice updated for '{book_name}'")
            print(f"Old Price: ₹{old_price} → New Price: ₹{new_price}")
        else:
            print("\nBook not found in library!")


# Main program
library = Library()

library.display_books()

book_name = input("\nEnter book name to update: ")
new_price = float(input("Enter new price: "))

library.update_price(book_name, new_price)

library.display_books()
