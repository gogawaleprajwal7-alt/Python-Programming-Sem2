class BillSplitter:

    def __init__(self, total_bill, people):
        self.total_bill = total_bill
        self.people = people

    def split_bill(self):
        try:
            amount_per_person = self.total_bill / self.people
            print(f"Each person has to pay: ₹{amount_per_person:.2f}")

        except ZeroDivisionError:
            print("Error: Cannot divide bill among zero people!")
        except Exception:
            print("Invalid input!")


# Main program
try:
    bill = float(input("Enter total bill amount: "))
    people = int(input("Enter number of people: "))

    splitter = BillSplitter(bill, people)
    splitter.split_bill()

except ValueError:
    print("Please enter valid numeric values.")
